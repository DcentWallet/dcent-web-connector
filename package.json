{
  "name": "dcent-web-connector",
  "version": "0.16.0",
  "description": "D'CENT Web SDK Connector",
  "main": "src-v1/index.js",
  "module": "src-v1/index.js",
  "scripts": {
    "dev": "yarn build-dev && webpack-dev-server --mode development",
    "build-dev": "webpack --mode development",
    "build": "webpack --mode production",
    "test": "yarn lint && jest --detectOpenHandles --coverage --forceExit --runInBand",
    "unit-mock": "jest --coverage --runInBand 0_mock_test",
    "unit-bridge": "jest --coverage --runInBand 1_bridge_test",
    "unit-v2": "jest --config jest.v2.config.js --runInBand tests/unit/v2",
    "unit-v2-e2e": "jest --config jest.v2-e2e.config.js --runInBand",
    "unit-v2-e2e:visual": "E2E_HEADLESS=false jest --config jest.v2-e2e.config.js --runInBand",
    "unit-v2-e2e:slowmo": "E2E_HEADLESS=false E2E_SLOWMO=100 jest --config jest.v2-e2e.config.js --runInBand",
    "unit-v2-e2e:devtools": "E2E_HEADLESS=false E2E_DEVTOOLS=true jest --config jest.v2-e2e.config.js --runInBand",
    "lint": "eslint --ext .js src-v1 tests playground.js",
    "lint:fix": "eslint --ext .js src-v1 tests playground.js --fix",
    "tsc": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-puppeteer",
    "globals": {
      "PATH": "http://localhost:9090"
    },
    "testEnvironment": "jsdom",
    "testSequencer": "./tests/testSequencer.js",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "coverageDirectory": "tests/coverage",
    "collectCoverage": true,
    "setupFilesAfterEnv": [
      "./tests/jest.setup.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DcentWallet/dcent-web-connector.git"
  },
  "keywords": [
    "D'CENT",
    "dcent",
    "hardware wallet",
    "wallet sdk",
    "D'CENT biometric wallet",
    "dcent sdk",
    "dcent web sdk",
    "dcentwallet",
    "dcent web connector"
  ],
  "homepage": "https://github.com/DcentWallet/dcent-web-connector#readme",
  "author": "IoTrust Co. Ltd.,",
  "devDependencies": {
    "@babel/core": "^7.6.0",
    "@babel/preset-env": "^7.6.0",
    "@babel/preset-react": "^7.9.4",
    "@babel/preset-typescript": "^7.28.5",
    "@noble/curves": "^1.0.0",
    "@scure/base": "^1.1.1",
    "@taquito/utils": "^16.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "babel-core": "^7.0.0-bridge.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^24.8.0",
    "babel-loader": "^8.0.6",
    "buffer": "^6.0.3",
    "caver-js": "^1.8.1",
    "clean-webpack-plugin": "^3.0.0",
    "copy-webpack-plugin": "^5.0.4",
    "eslint": "^6.2.1",
    "eslint-config-standard": "^10.2.1",
    "eslint-friendly-formatter": "^4.0.1",
    "eslint-loader": "^3.0.0",
    "eslint-plugin-html": "^6.0.0",
    "eslint-plugin-jest": "^23.13.2",
    "eslint-plugin-json": "^2.1.1",
    "eslint-plugin-mocha": "^6.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "expect-puppeteer": "^4.4.0",
    "hi-base32": "^0.5.1",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^25.4.0",
    "jest-puppeteer": "^6.2.0",
    "near-api-js": "^2.1.3",
    "path": "^0.12.7",
    "puppeteer": "^10.4.0",
    "regenerator-runtime": "^0.13.3",
    "thor-devkit": "^2.0.7",
    "ts-loader": "^9.5.1",
    "tweetnacl": "^1.0.3",
    "typescript": "~5.9.3",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.9.0"
  },
  "dependencies": {
    "bignumber.js": "^9.1.1",
    "events": "^3.0.0"
  },
  "engines": {
    "node": ">= 18.0.0",
    "npm": ">= 9.0.0"
  },
  "license": "MIT"
}
